Package: etvpn
Architecture: all
Depends: ${perl:Depends},
         ${misc:Depends},
         etvpn-web (= ${binary:Version}),
         openvpn (>= 2.5),
         oathtool (>= 2.6.5),
         acl,
         libauthen-webauthn-perl,
         libbytes-random-secure-perl,
         libcbor-xs-perl,
         libcgi-session-perl,
         libconfig-inifiles-perl,
         libconvert-base32-perl,
         libcrypt-openssl-rsa-perl,
         libdbi-perl,
         libdigest-sha-perl,
         libio-interactive-perl,
         libjson-perl,
         liblist-moreutils-perl,
         libmime-base64-perl,
